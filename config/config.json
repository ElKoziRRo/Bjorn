{
	"network_scan": {
    "enabled": true,
    "range": "192.168.1.0/24",
    "scan_type": "service",
    "ports": "21,22,23,80,139,445,3306,3389,6379,27017"
},

"os_detection": {
    "enabled": true,
    "method": "nmap"
},
	
  "general": {
    "threads": 10,
    "timeout": 5,
	"retry": 1,
    "log_level": "info"
  },
  
  "logging": {
    "enabled": true,
    "file": "data/logs/bjorn.log",
    "rotate": true,
    "max_size": "15MB"
},

  "ssh": {
    "enabled": true,
    "port": 22,
    "usernames": "data/input/dictionary/sql_users.txt",
    "passwords": "data/input/dictionary/ssh_common.txt",
    "notes": "Szybki wordlist do SSH — najczęstsze hasła i loginy."
  },

  "ftp": {
    "enabled": true,
    "port": 21,
    "usernames": "data/input/dictionary/sql_users.txt",
    "passwords": "data/input/dictionary/ftp_default.txt",
    "notes": "Typowe loginy i hasła FTP, w tym anonymous."
  },

  "smb": {
    "enabled": true,
    "port": 445,
    "usernames": "data/input/dictionary/sql_users.txt",
    "passwords": "data/input/dictionary/smb_pass.txt",
    "notes": "Hasła SMB/Windows — krótkie i skuteczne."
  },

  "mysql": {
    "enabled": true,
    "port": 3306,
    "usernames": "data/input/dictionary/sql_users.txt",
    "passwords": "data/input/dictionary/sql_passwords.txt",
    "notes": "Typowe loginy i hasła do baz SQL."
  },

  "http_basic": {
    "enabled": true,
    "usernames": "data/input/dictionary/sql_users.txt",
    "passwords": "data/input/dictionary/http_basic.txt",
    "notes": "Do testowania HTTP Basic Auth."
  },

  "bruteforce_full": {
    "enabled": true,
    "wordlist": "data/input/dictionary/rockyou-1k.txt",
    "notes": "Wersja cięższa — tylko jeśli chcesz pełny brute-force."
  },

  "report": {
    "enabled": true,
    "output": "data/last_report.html"
}
